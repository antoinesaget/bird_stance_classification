<View style="display: flex; align-items: flex-start; gap: 16px;">
  <View style="flex: 1 1 auto; min-width: 0;">
    <Header value="Bird Annotation &amp; Classification"/>
    <Image name="image" value="$image" zoom="true"/>
    <RectangleLabels name="bird_bbox" toName="image">
      <Label value="Bird" background="#34A853"/>
    </RectangleLabels>
  </View>

  <View style="width: 34%; min-width: 360px;">
    <Header value="Image-Level Usability"/>
    <Choices
      name="image_status"
      toName="image"
      required="true"
      choice="single-radio"
      showInline="true">
      <Choice value="has_usable_birds" hotkey="a"/>
      <Choice value="no_usable_birds" hotkey="q"/>
    </Choices>

    <Header value="Per-Bird Readability"/>
    <Choices
      name="readability"
      toName="image"
      perRegion="true"
      whenTagName="bird_bbox"
      choice="single-radio"
      required="true"
      showInline="true">
      <Choice value="readable" selected="true" hotkey="z"/>
      <Choice value="unreadable" hotkey="x"/>
    </Choices>

    <Header value="Bird Activity (Readable Birds)"/>
    <Choices
      name="activity"
      toName="image"
      perRegion="true"
      whenTagName="bird_bbox"
      choice="single-radio"
      required="false"
      showInline="true">
      <Choice value="flying" hotkey="e"/>
      <Choice value="foraging" hotkey="d"/>
      <Choice value="standing" hotkey="c"/>
    </Choices>

    <Header value="Bird Position (Readable Birds)"/>
    <Choices
      name="support"
      toName="image"
      perRegion="true"
      whenTagName="bird_bbox"
      choice="single-radio"
      required="false"
      showInline="true">
      <Choice value="ground" hotkey="r"/>
      <Choice value="water" hotkey="f"/>
      <Choice value="air" hotkey="v"/>
    </Choices>

    <Header value="Visible Legs (Standing Birds)"/>
    <Choices
      name="legs"
      toName="image"
      perRegion="true"
      whenTagName="bird_bbox"
      choice="single-radio"
      required="false"
      showInline="true">
      <Choice value="one" hotkey="t"/>
      <Choice value="two" hotkey="g"/>
      <Choice value="unsure" hotkey="b"/>
    </Choices>

    <Header value="Back Resting (Standing Birds)"/>
    <Choices
      name="resting_back"
      toName="image"
      perRegion="true"
      whenTagName="bird_bbox"
      choice="single-radio"
      required="false"
      showInline="true">
      <Choice value="yes" hotkey="y"/>
      <Choice value="no" selected="true" hotkey="h"/>
    </Choices>
  </View>
</View>
