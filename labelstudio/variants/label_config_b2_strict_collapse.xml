<View style="display: flex; align-items: flex-start; gap: 10px;">
  <View style="flex: 1 1 auto; min-width: 0;">
    <Header value="Bird Annotation &amp; Classification" size="5"/>
    <Image name="image" value="$image" zoom="true"/>
    <RectangleLabels name="bird_bbox" toName="image">
      <Label value="Bird" background="#34A853" hotkey="1"/>
    </RectangleLabels>
  </View>

  <View style="width: 34%; min-width: 330px;">
    <Header value="Image status" size="6"/>
    <Choices name="image_status" toName="image" required="true" choice="single-radio" showInline="true" layout="inline">
      <Choice value="has_usable_birds" hotkey="a"/>
      <Choice value="no_usable_birds" hotkey="q"/>
    </Choices>

    <Collapse accordion="false">
      <Panel value="Core" open="true">
        <Header value="Readability" size="7"/>
        <Choices name="readability" toName="image" perRegion="true" whenTagName="bird_bbox" required="true" choice="single-radio" showInline="true" layout="inline">
          <Choice value="readable" selected="true" hotkey="z"/>
          <Choice value="occluded" hotkey="x"/>
          <Choice value="unreadable" hotkey="c"/>
        </Choices>

        <Header value="Species quality" size="7"/>
        <Choices name="specie" toName="image" perRegion="true" whenTagName="bird_bbox" required="true" choice="single-radio" showInline="true" layout="inline">
          <Choice value="correct" selected="true" hotkey="s"/>
          <Choice value="incorrect" hotkey="d"/>
          <Choice value="unsure" hotkey="f"/>
        </Choices>
      </Panel>
    </Collapse>

    <View visibleWhen="choice-unselected" whenTagName="readability" whenChoiceValue="unreadable">
      <View visibleWhen="choice-unselected" whenTagName="specie" whenChoiceValue="incorrect">
        <Collapse accordion="false">
          <Panel value="Context" open="true">
            <Header value="Behavior" size="7"/>
            <Choices name="behavior" toName="image" perRegion="true" whenTagName="bird_bbox" required="true" choice="single-radio" showInline="true" layout="inline">
              <Choice value="flying" hotkey="e"/>
              <Choice value="foraging" hotkey="r"/>
              <Choice value="resting" hotkey="t"/>
              <Choice value="backresting" hotkey="y"/>
              <Choice value="preening" hotkey="u"/>
              <Choice value="display" hotkey="i"/>
              <Choice value="unsure" hotkey="o"/>
            </Choices>

            <Header value="Substrate" size="7"/>
            <Choices name="substrate" toName="image" perRegion="true" whenTagName="bird_bbox" required="true" choice="single-radio" showInline="true" layout="inline">
              <Choice value="ground" hotkey="g"/>
              <Choice value="water" hotkey="w"/>
              <Choice value="air" hotkey="v"/>
              <Choice value="unsure" hotkey="b"/>
            </Choices>
          </Panel>
        </Collapse>

        <View visibleWhen="choice-selected" whenTagName="behavior" whenChoiceValue="resting,backresting">
          <View visibleWhen="choice-selected" whenTagName="substrate" whenChoiceValue="ground,water">
            <Collapse accordion="false">
              <Panel value="Legs" open="true">
                <Header value="Visible legs" size="7"/>
                <Choices name="legs" toName="image" perRegion="true" whenTagName="bird_bbox" required="true" choice="single-radio" showInline="true" layout="inline">
                  <Choice value="one" hotkey="1"/>
                  <Choice value="two" hotkey="2"/>
                  <Choice value="unsure" selected="true" hotkey="3"/>
                </Choices>
              </Panel>
            </Collapse>
          </View>
        </View>
      </View>
    </View>
  </View>
</View>
