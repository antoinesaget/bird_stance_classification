<View style="display: flex; align-items: flex-start; gap: 16px;">
  <View style="flex: 1 1 auto; min-width: 0;">
    <Header value="Bird Annotation &amp; Classification"/>
    <Image name="image" value="$image" zoom="true"/>
    <RectangleLabels name="bird_bbox" toName="image">
      <Label value="Bird" background="#34A853" hotkey="1"/>
    </RectangleLabels>
  </View>

  <View style="width: 36%; min-width: 380px;">
    <Header value="Image-Level Usability"/>
    <Choices name="image_status" toName="image" required="true" choice="single-radio" showInline="true">
      <Choice value="has_usable_birds" hotkey="a"/>
      <Choice value="no_usable_birds" hotkey="q"/>
    </Choices>

    <View visibleWhen="region-selected" whenTagName="bird_bbox">
      <Header value="Readability"/>
      <Choices name="readability" toName="image" perRegion="true" whenTagName="bird_bbox" required="true" choice="single-radio" showInline="true">
        <Choice value="readable" selected="true" hotkey="z"/>
        <Choice value="occluded" hotkey="s"/>
        <Choice value="unreadable" hotkey="x"/>
      </Choices>

      <Header value="Specie"/>
      <Choices name="specie" toName="image" perRegion="true" whenTagName="bird_bbox" required="true" choice="single-radio" showInline="true">
        <Choice value="correct" selected="true" hotkey="e"/>
        <Choice value="incorrect" hotkey="d"/>
        <Choice value="unsure" hotkey="c"/>
      </Choices>

      <View visibleWhen="choice-unselected" whenTagName="readability" whenChoiceValue="unreadable">
        <View visibleWhen="choice-unselected" whenTagName="specie" whenChoiceValue="incorrect">
          <Header value="Behavior"/>
          <Choices name="behavior" toName="image" perRegion="true" whenTagName="bird_bbox" required="true" choice="single-radio" showInline="true">
            <Choice value="resting" hotkey="r"/>
            <Choice value="foraging" hotkey="f"/>
            <Choice value="flying" hotkey="v"/>
            <Choice value="backresting"/>
            <Choice value="preening"/>
            <Choice value="display"/>
            <Choice value="unsure"/>
          </Choices>

          <Header value="Substrate"/>
          <Choices name="substrate" toName="image" perRegion="true" whenTagName="bird_bbox" required="true" choice="single-radio" showInline="true">
            <Choice value="ground" hotkey="t"/>
            <Choice value="water" hotkey="g"/>
            <Choice value="air" hotkey="b"/>
            <Choice value="unsure"/>
          </Choices>

          <View visibleWhen="choice-selected" whenTagName="behavior" whenChoiceValue="resting,backresting">
            <View visibleWhen="choice-selected" whenTagName="substrate" whenChoiceValue="ground,water">
              <Header value="Stance"/>
              <Choices name="legs" toName="image" perRegion="true" whenTagName="bird_bbox" required="false" choice="single-radio" showInline="true">
                <Choice value="one" hotkey="y"/>
                <Choice value="two" hotkey="h"/>
                <Choice value="unsure" selected="true" hotkey="n"/>
                <Choice value="sitting"/>
              </Choices>
            </View>
          </View>
        </View>
      </View>
    </View>
  </View>
</View>
