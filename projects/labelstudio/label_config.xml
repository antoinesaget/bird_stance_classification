<View style="display: flex; align-items: flex-start; gap: 16px;">
  <View style="flex: 1 1 auto; min-width: 0;">
    <Header value="Bird Annotation &amp; Classification"/>
    <Image name="image" value="$image" zoom="true"/>
    <RectangleLabels name="bird_bbox" toName="image">
      <Label value="Bird" background="#34A853" hotkey="1"/>
    </RectangleLabels>
  </View>

  <View style="width: 36%; min-width: 380px;">
    <View visibleWhen="region-selected" whenTagName="bird_bbox">
      <Header value="Per-Bird Core"/>
      <Choices
        name="isbird"
        toName="image"
        perRegion="true"
        whenTagName="bird_bbox"
        choice="single-radio"
        required="true"
        showInline="true">
        <Choice value="yes" selected="true" hotkey="a"/>
        <Choice value="no" hotkey="q"/>
      </Choices>

      <View visibleWhen="choice-selected" whenTagName="isbird" whenChoiceValue="yes">
      <Choices
        name="readability"
        toName="image"
        perRegion="true"
        whenTagName="bird_bbox"
        choice="single-radio"
        required="true"
        showInline="true">
        <Choice value="readable" selected="true" hotkey="z"/>
        <Choice value="occluded" hotkey="x"/>
        <Choice value="unreadable" hotkey="c"/>
      </Choices>

      <Choices
        name="specie"
        toName="image"
        perRegion="true"
        whenTagName="bird_bbox"
        choice="single-radio"
        required="true"
        showInline="true">
        <Choice value="correct" selected="true" hotkey="s"/>
        <Choice value="incorrect" hotkey="d"/>
        <Choice value="unsure" hotkey="f"/>
      </Choices>

      <View visibleWhen="choice-unselected" whenTagName="readability" whenChoiceValue="unreadable">
        <View visibleWhen="choice-unselected" whenTagName="specie" whenChoiceValue="incorrect">
          <Header value="Per-Bird Context"/>
          <Choices
            name="behavior"
            toName="image"
            perRegion="true"
            whenTagName="bird_bbox"
            choice="single-radio"
            required="false"
            showInline="true">
            <Choice value="flying" hotkey="e"/>
            <Choice value="moving" hotkey="r"/>
            <Choice value="foraging" hotkey="t"/>
            <Choice value="resting" hotkey="y"/>
            <Choice value="backresting" hotkey="u"/>
            <Choice value="bathing" hotkey="i"/>
            <Choice value="calling" hotkey="o"/>
            <Choice value="preening" hotkey="p"/>
            <Choice value="display"/>
            <Choice value="breeding"/>
            <Choice value="other"/>
            <Choice value="unsure"/>
          </Choices>

          <Choices
            name="substrate"
            toName="image"
            perRegion="true"
            whenTagName="bird_bbox"
            choice="single-radio"
            required="false"
            showInline="true">
            <Choice value="bare_ground" hotkey="g"/>
            <Choice value="vegetation" hotkey="v"/>
            <Choice value="water" hotkey="w"/>
            <Choice value="air" hotkey="b"/>
            <Choice value="unsure" hotkey="n"/>
          </Choices>

          <View visibleWhen="choice-selected" whenTagName="behavior" whenChoiceValue="resting,backresting">
            <View visibleWhen="choice-selected" whenTagName="substrate" whenChoiceValue="bare_ground,water,unsure">
              <Header value="Stance (Resting on Bare Ground/Water/Unsure)"/>
              <Choices
                name="stance"
                toName="image"
                perRegion="true"
                whenTagName="bird_bbox"
                choice="single-radio"
                required="false"
                showInline="true">
                <Choice value="unipedal" hotkey="1"/>
                <Choice value="bipedal" hotkey="2"/>
                <Choice value="sitting" hotkey="3"/>
                <Choice value="unsure" selected="true" hotkey="4"/>
              </Choices>
            </View>
          </View>
        </View>
      </View>
      </View>
    </View>
  </View>
</View>
