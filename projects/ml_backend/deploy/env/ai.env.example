# Purpose: Document the environment variables required by the ai ML backend deployment.
DEPLOY_BRANCH=main
BIRD_DATA_HOME=/data/birds
BIRD_SPECIES_SLUG=black_winged_stilt
MODEL_A_BOOTSTRAP_WEIGHTS=/home/antoine/_archives/bird_stance_classification/2026-04-12/repo-root/weights/yolo11m.pt
MODEL_A_SERVING_WEIGHTS=/data/birds/black_winged_stilt/models/detector/served/model_a/current/weights.pt
MODEL_A_DEVICE=0
MODEL_A_IMGSZ=1280
MODEL_A_MAX_DET=300
MODEL_A_CONF=0.25
MODEL_A_IOU=0.45
MODEL_B_SERVING_ARTIFACT=/data/birds/black_winged_stilt/models/attributes/served/model_b/current
BIRDS_LOG_LEVEL=INFO
ML_BACKEND_PORT=9090
ML_BACKEND_BIND_HOST=0.0.0.0
REQUIRE_NON_CPU_DEVICE=1
