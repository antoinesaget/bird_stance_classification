# Shared image directory override (optional).
# If empty, shared/scripts/detect_images.py will fall back to ./images, ./data/images,
# ./dataset/images, then scraped_images paths used in this repo.
BIRD_IMAGES_DIR=

# Docker compose bind mount source for images in POCs.
# Relative values are resolved from each poc-* folder.
IMAGE_DIR=../images

# Shared YOLO inference defaults
YOLO_MODEL=yolo11n.pt
YOLO_CONF=0.25
YOLO_IOU=0.45
YOLO_MAX_DET=300
YOLO_IMGSZ=1280
# Docker on macOS runs Linux containers, so use cpu by default.
YOLO_DEVICE=cpu

# Label Studio optional settings
LABEL_STUDIO_API_TOKEN=
LABEL_STUDIO_URL=http://localhost:8081

# CVAT settings
CVAT_VERSION=latest
CVAT_HOST=localhost
CVAT_YOLO_MODEL=yolo11n.pt
CVAT_TARGET_LABEL=bird
CVAT_YOLO_CONF=0.25
CVAT_YOLO_IOU=0.45
CVAT_YOLO_MAX_DET=300
CVAT_YOLO_IMGSZ=1280
CVAT_YOLO_DEVICE=cpu
